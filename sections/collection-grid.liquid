          "min": 10,
          "max": 70,
          "step": 1,
          "unit": "%",
          "label": "Card hover gate opening",
          "default": 46
        },
        {
          "type": "text",
          "id": "title",
          "label": "Optional title"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Optional caption"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection link"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product link"
        },
        {
          "type": "url",
          "id": "custom_link",
          "label": "Custom link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Charlotte collection grid",
      "blocks": [
        {
          "type": "artwork",
          "settings": {
            "hover_open_amount": 42
          }
        },
        {
          "type": "artwork",
          "settings": {
            "hover_open_amount": 46
          }
        },
        {
          "type": "artwork",
          "settings": {
            "hover_open_amount": 50
          }
        },
        {
          "type": "artwork",
          "settings": {
            "hover_open_amount": 44

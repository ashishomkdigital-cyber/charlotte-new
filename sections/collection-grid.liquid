{% comment %}
  Charlotte collection grid
  Drop this file into /sections and add it from the Shopify theme editor.
{% endcomment %}

{%- liquid
  assign section_id = 'charlotte-collection-grid-' | append: section.id
  assign columns_desktop = section.settings.columns_desktop
  assign columns_tablet = section.settings.columns_tablet
  assign columns_mobile = section.settings.columns_mobile
-%}

<section
  id="{{ section_id }}"
  class="charlotte-collection-grid color-{{ section.id }}"
  style="
    --ccg-bg: {{ section.settings.background_color }};
    --ccg-text: {{ section.settings.text_color }};
    --ccg-muted: {{ section.settings.muted_text_color }};
    --ccg-max-width: {{ section.settings.max_width }}px;
    --ccg-gap-desktop: {{ section.settings.gap_desktop }}px;
    --ccg-gap-mobile: {{ section.settings.gap_mobile }}px;
    --ccg-columns-desktop: {{ columns_desktop }};
    --ccg-columns-tablet: {{ columns_tablet }};
    --ccg-columns-mobile: {{ columns_mobile }};
    --ccg-image-width: {{ section.settings.image_width }}%;
    --ccg-padding-top: {{ section.settings.padding_top }}px;
    --ccg-padding-bottom: {{ section.settings.padding_bottom }}px;
    --ccg-heading-size: {{ section.settings.heading_size }}px;
    --ccg-body-size: {{ section.settings.body_size }}px;
    --ccg-art-ratio: {{ section.settings.art_ratio }};
    --ccg-hover-open: {{ section.settings.hover_open_amount }}%;
    --ccg-hover-duration: {{ section.settings.hover_duration }}ms;
    --ccg-click-duration: {{ section.settings.click_duration }}ms;
    --ccg-click-scale: {{ section.settings.click_scale | divided_by: 100.0 }};
  "
>
  <div class="charlotte-collection-grid__inner">
    {%- if section.settings.heading != blank or section.settings.text != blank -%}
      <div class="charlotte-collection-grid__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="charlotte-collection-grid__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="charlotte-collection-grid__text">{{ section.settings.text }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="charlotte-collection-grid__items">
      {%- for block in section.blocks -%}
        {%- liquid
          assign block_url = block.settings.custom_link
          if block_url == blank and block.settings.collection != blank
            assign block_url = block.settings.collection.url
          endif
          if block_url == blank and block.settings.product != blank
            assign block_url = block.settings.product.url
          endif
          assign reveal_title = block.settings.title
          if reveal_title == blank and block.settings.collection != blank
            assign reveal_title = block.settings.collection.title
          endif
          if reveal_title == blank and block.settings.product != blank
            assign reveal_title = block.settings.product.title
          endif
          if reveal_title == blank
            assign reveal_title = section.settings.heading
          endif
        -%}

        <div class="charlotte-collection-grid__item" {{ block.shopify_attributes }}>
          {%- if block_url != blank -%}
            <a class="charlotte-collection-grid__link" href="{{ block_url }}" aria-label="{{ reveal_title | escape }}" data-charlotte-card-link>
          {%- else -%}
            <div class="charlotte-collection-grid__link" role="group" aria-label="{{ reveal_title | escape }}">
          {%- endif -%}

            <div class="charlotte-collection-grid__art" style="--ccg-card-hover-open: {{ block.settings.hover_open_amount }}%;">
              <div class="charlotte-collection-grid__stage">
                {%- if block.settings.simple_gate_image != blank -%}
                  {{
                    block.settings.simple_gate_image
                    | image_url: width: 1100
                    | image_tag:
                      loading: 'lazy',
                      sizes: '(min-width: 990px) 31vw, (min-width: 750px) 45vw, 86vw',
                      widths: '320, 480, 640, 800, 960, 1100',
                      class: 'charlotte-collection-grid__layer charlotte-collection-grid__layer--simple',
                      alt: ''
                  }}
                {% comment %} {%- else -%}
                  <img
                    src="{{ 'simple-gate.png' | asset_url }}"
                    alt=""
                    loading="lazy"
                    class="charlotte-collection-grid__layer charlotte-collection-grid__layer--simple"
                    width="1100"
                    height="1287"
                  > {% endcomment %}
                {%- endif -%}

                {%- if reveal_title != blank -%}
                  <div class="charlotte-collection-grid__reveal" aria-hidden="true">
                    <span>{{ reveal_title }}</span>
                  </div>
                {%- endif -%}

                {%- if block.settings.left_gate_image != blank -%}
                  {{
                    block.settings.left_gate_image
                    | image_url: width: 760
                    | image_tag:
                      loading: 'lazy',
                      sizes: '(min-width: 990px) 16vw, (min-width: 750px) 24vw, 43vw',
                      widths: '260, 380, 520, 640, 760',
                      class: 'charlotte-collection-grid__layer charlotte-collection-grid__gate charlotte-collection-grid__gate--left',
                      alt: ''
                  }}
                {%- else -%}
                  <img
                    src="{{ 'rose-gate-left.png' | asset_url }}"
                    alt=""
                    loading="lazy"
                    class="charlotte-collection-grid__layer charlotte-collection-grid__gate charlotte-collection-grid__gate--left"
                    width="760"
                    height="1287"
                  >
                {%- endif -%}

                {%- if block.settings.right_gate_image != blank -%}
                  {{
                    block.settings.right_gate_image
                    | image_url: width: 760
                    | image_tag:
                      loading: 'lazy',
                      sizes: '(min-width: 990px) 16vw, (min-width: 750px) 24vw, 43vw',
                      widths: '260, 380, 520, 640, 760',
                      class: 'charlotte-collection-grid__layer charlotte-collection-grid__gate charlotte-collection-grid__gate--right',
                      alt: ''
                  }}
                {%- else -%}
                  <img
                    src="{{ 'rose-gate-right.png' | asset_url }}"
                    alt=""
                    loading="lazy"
                    class="charlotte-collection-grid__layer charlotte-collection-grid__gate charlotte-collection-grid__gate--right"
                    width="760"
                    height="1287"
                  >
                {%- endif -%}

                {%- if block.settings.frame_image != blank -%}
                  {%- liquid
                    assign frame_alt = block.settings.frame_image.alt
                    if frame_alt == blank
                      assign frame_alt = block.settings.title
                    endif
                  -%}
                  {{
                    block.settings.frame_image
                    | image_url: width: 1100
                    | image_tag:
                      loading: 'lazy',
                      sizes: '(min-width: 990px) 31vw, (min-width: 750px) 45vw, 86vw',
                      widths: '320, 480, 640, 800, 960, 1100',
                      class: 'charlotte-collection-grid__layer charlotte-collection-grid__layer--frame',
                      alt: frame_alt
                  }}
                {%- elsif block.settings.image != blank -%}
                  {%- liquid
                    assign image_alt = block.settings.image.alt
                    if image_alt == blank
                      assign image_alt = block.settings.title
                    endif
                  -%}
                  {{
                    block.settings.image
                    | image_url: width: 1100
                    | image_tag:
                      loading: 'lazy',
                      sizes: '(min-width: 990px) 31vw, (min-width: 750px) 45vw, 86vw',
                      widths: '320, 480, 640, 800, 960, 1100',
                      class: 'charlotte-collection-grid__layer charlotte-collection-grid__layer--frame',
                      alt: image_alt
                  }}
                {%- else -%}
                  <img
                    src="{{ 'frame.png' | asset_url }}"
                    alt="{{ reveal_title | escape }}"
                    loading="lazy"
                    class="charlotte-collection-grid__layer charlotte-collection-grid__layer--frame"
                    width="1100"
                    height="1287"
                  >
                {%- endif -%}
              </div>
            </div>

            {%- if block.settings.title != blank or block.settings.caption != blank -%}
              <div class="charlotte-collection-grid__caption">
                {%- if block.settings.title != blank -%}
                  <h3>{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.caption != blank -%}
                  <p>{{ block.settings.caption }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}

          {%- if block_url != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #{{ section_id }} {
    background: var(--ccg-bg);
    color: var(--ccg-text);
    padding-block: var(--ccg-padding-top) var(--ccg-padding-bottom);
  }

  #{{ section_id }} .charlotte-collection-grid__inner {
    width: min(100% - 32px, var(--ccg-max-width));
    margin-inline: auto;
  }

  #{{ section_id }} .charlotte-collection-grid__header {
    max-width: 660px;
    margin: 0 auto 34px;
    text-align: center;
  }

  #{{ section_id }} .charlotte-collection-grid__heading {
    margin: 0;
    color: var(--ccg-text);
    font-family: var(--font-heading-family);
    font-size: clamp(26px, 3vw, var(--ccg-heading-size));
    font-weight: 400;
    line-height: 1.12;
  }

  #{{ section_id }} .charlotte-collection-grid__text {
    margin-top: 12px;
    color: var(--ccg-muted);
    font-family: var(--font-body-family);
    font-size: var(--ccg-body-size);
    line-height: 1.6;
  }

  #{{ section_id }} .charlotte-collection-grid__text p {
    margin: 0;
  }

  #{{ section_id }} .charlotte-collection-grid__items {
    display: grid;
    grid-template-columns: repeat(var(--ccg-columns-desktop), minmax(0, 1fr));
    gap: var(--ccg-gap-desktop);
    align-items: start;
  }

  #{{ section_id }} .charlotte-collection-grid__item {
    min-width: 0;
  }

  #{{ section_id }} .charlotte-collection-grid__link {
    display: block;
    color: inherit;
    text-decoration: none;
    cursor: pointer;
  }

  #{{ section_id }} .charlotte-collection-grid__art {
    position: relative;
    width: min(100%, var(--ccg-image-width));
    margin-inline: auto;
    isolation: isolate;
  }

  #{{ section_id }} .charlotte-collection-grid__stage {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: var(--ccg-art-ratio);
    overflow: hidden;
    contain: paint;
  }

  #{{ section_id }} .charlotte-collection-grid__layer {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    user-select: none;
    -webkit-user-drag: none;
  }

  #{{ section_id }} .charlotte-collection-grid__layer--simple {
    z-index: 1;
  }

  #{{ section_id }} .charlotte-collection-grid__reveal {
    position: absolute;
    inset: 18% 18% 20%;
    z-index: 1;
    display: grid;
    place-items: center;
    padding: 18px;
    text-align: center;
    pointer-events: none;
    opacity: 0.88;
  }

  #{{ section_id }} .charlotte-collection-grid__reveal span {
    display: block;
    max-width: 12ch;
    color: var(--ccg-text);
    font-family: var(--font-heading-family);
    font-size: clamp(19px, 2.1vw, 32px);
    font-weight: 400;
    line-height: 1.08;
    text-wrap: balance;
    transform: translateY(8px) scale(0.96);
    opacity: 0;
    transition:
      transform var(--ccg-hover-duration) cubic-bezier(0.22, 1, 0.36, 1),
      opacity calc(var(--ccg-hover-duration) * 0.72) ease;
  }

  #{{ section_id }} .charlotte-collection-grid__gate {
    z-index: 2;
    top: 0;
    bottom: 0;
    width: 50%;
    height: 100%;
    object-fit: contain;
    will-change: transform, opacity;
    transition:
      transform var(--ccg-hover-duration) cubic-bezier(0.22, 1, 0.36, 1),
      opacity var(--ccg-click-duration) ease;
  }

  #{{ section_id }} .charlotte-collection-grid__gate--left {
    left: 0;
    right: auto;
    object-position: right center;
    transform-origin: right center;
  }

  #{{ section_id }} .charlotte-collection-grid__gate--right {
    left: auto;
    right: 0;
    object-position: left center;
    transform-origin: left center;
  }

  #{{ section_id }} .charlotte-collection-grid__layer--frame {
    z-index: 3;
    pointer-events: none;
    transform: scale(1.05);
  }

  #{{ section_id }} .charlotte-collection-grid__link:hover .charlotte-collection-grid__gate--left,
  #{{ section_id }} .charlotte-collection-grid__link:focus-visible .charlotte-collection-grid__gate--left {
    transform: translateX(calc(var(--ccg-card-hover-open, var(--ccg-hover-open)) * -1)) scale(0.8);
  }

  #{{ section_id }} .charlotte-collection-grid__link:hover .charlotte-collection-grid__gate--right,
  #{{ section_id }} .charlotte-collection-grid__link:focus-visible .charlotte-collection-grid__gate--right {
    transform: translateX(var(--ccg-card-hover-open, var(--ccg-hover-open))) scale(0.8);
  }

  #{{ section_id }} .charlotte-collection-grid__link:hover .charlotte-collection-grid__reveal span,
  #{{ section_id }} .charlotte-collection-grid__link:focus-visible .charlotte-collection-grid__reveal span {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  #{{ section_id }} .charlotte-collection-grid__link.is-opening {
    pointer-events: none;
  }

  #{{ section_id }} .charlotte-collection-grid__link.is-opening .charlotte-collection-grid__gate {
    opacity: 0;
    transition:
      transform var(--ccg-click-duration) cubic-bezier(0.16, 1, 0.3, 1),
      opacity calc(var(--ccg-click-duration) * 0.82) ease;
  }

  #{{ section_id }} .charlotte-collection-grid__link.is-opening .charlotte-collection-grid__gate--left {
    transform: translateX(-42%) scale(var(--ccg-click-scale));
  }

  #{{ section_id }} .charlotte-collection-grid__link.is-opening .charlotte-collection-grid__gate--right {
    transform: translateX(42%) scale(var(--ccg-click-scale));
  }

  #{{ section_id }} .charlotte-collection-grid__link.is-opening .charlotte-collection-grid__reveal span {
    opacity: 1;
    transform: translateY(0) scale(1.04);
  }

  @media (prefers-reduced-motion: reduce) {
    #{{ section_id }} .charlotte-collection-grid__gate {
      transition: none;
    }
  }

  #{{ section_id }} .charlotte-collection-grid__caption {
    max-width: var(--ccg-image-width);
    margin: 14px auto 0;
    text-align: center;
  }

  #{{ section_id }} .charlotte-collection-grid__caption h3 {
    margin: 0;
    color: var(--ccg-text);
    font-family: var(--font-heading-family);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.2;
  }

  #{{ section_id }} .charlotte-collection-grid__caption p {
    margin: 6px 0 0;
    color: var(--ccg-muted);
    font-family: var(--font-body-family);
    font-size: 14px;
    line-height: 1.45;
  }

  @media screen and (max-width: 989px) {
    #{{ section_id }} .charlotte-collection-grid__items {
      grid-template-columns: repeat(var(--ccg-columns-tablet), minmax(0, 1fr));
      gap: var(--ccg-gap-mobile);
    }
  }

  @media screen and (max-width: 749px) {
    #{{ section_id }} {
      padding-block: calc(var(--ccg-padding-top) * 0.72) calc(var(--ccg-padding-bottom) * 0.72);
    }

    #{{ section_id }} .charlotte-collection-grid__inner {
      width: min(100% - 28px, var(--ccg-max-width));
    }

    #{{ section_id }} .charlotte-collection-grid__header {
      margin-bottom: 26px;
    }

    #{{ section_id }} .charlotte-collection-grid__items {
      grid-template-columns: repeat(var(--ccg-columns-mobile), minmax(0, 1fr));
    }
  }
</style>

<script>
  (() => {
    const section = document.getElementById({{ section_id | json }});

    if (!section || section.dataset.charlotteGateReady === 'true') {
      return;
    }

    section.dataset.charlotteGateReady = 'true';

    section.addEventListener('click', (event) => {
      if (!(event.target instanceof Element)) {
        return;
      }

      const link = event.target.closest('[data-charlotte-card-link]');

      if (!link || !section.contains(link)) {
        return;
      }

      const url = link.getAttribute('href');
      const target = link.getAttribute('target');
      const isModifiedClick = event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || event.button !== 0;

      if (!url || url.charAt(0) === '#' || target === '_blank' || isModifiedClick || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        return;
      }

      event.preventDefault();
      if (link.classList.contains('is-opening')) {
        return;
      }

      link.classList.add('is-opening');

      window.setTimeout(() => {
        window.location.href = url;
      }, {{ section.settings.click_duration | plus: 80 }});
    });
  })();
</script>

{% schema %}
{
  "name": "Charlotte collection grid",
  "tag": "section",
  "class": "section-charlotte-collection-grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Collection"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Discover the essential pieces from the Charlotte collection.</p>"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#e4d2bb"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading color",
      "default": "#2b2119"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Text color",
      "default": "#8f8171"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 960,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "label": "Maximum width",
      "default": 1440
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 70,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Artwork width",
      "default": 88
    },
    {
      "type": "select",
      "id": "art_ratio",
      "label": "Artwork ratio",
      "default": "1 / 1.17",
      "options": [
        {
          "value": "1 / 1",
          "label": "Square"
        },
        {
          "value": "1 / 1.17",
          "label": "Portrait"
        },
        {
          "value": "4 / 5",
          "label": "4:5"
        }
      ]
    },
    {
      "type": "range",
      "id": "hover_open_amount",
      "min": 10,
      "max": 70,
      "step": 1,
      "unit": "%",
      "label": "Hover gate opening",
      "default": 46
    },
    {
      "type": "range",
      "id": "hover_duration",
      "min": 250,
      "max": 1200,
      "step": 50,
      "unit": "ms",
      "label": "Hover duration",
      "default": 650
    },
    {
      "type": "range",
      "id": "click_duration",
      "min": 300,
      "max": 1600,
      "step": 50,
      "unit": "ms",
      "label": "Click animation duration",
      "default": 850
    },
    {
      "type": "range",
      "id": "click_scale",
      "min": 160,
      "max": 320,
      "step": 10,
      "unit": "%",
      "label": "Click gate scale",
      "default": 220
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns on desktop",
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Columns on tablet",
      "default": 2
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "default": "1",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ]
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "min": 16,
      "max": 96,
      "step": 2,
      "unit": "px",
      "label": "Desktop gap",
      "default": 42
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "min": 12,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Mobile gap",
      "default": 26
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 28,
      "max": 72,
      "step": 1,
      "unit": "px",
      "label": "Heading size",
      "default": 34
    },
    {
      "type": "range",
      "id": "body_size",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 24,

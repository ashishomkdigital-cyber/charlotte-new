        },
        {
          "type": "image_picker",
          "id": "left_gate_image",
          "label": "Left gate image"
        },
        {
          "type": "image_picker",
          "id": "right_gate_image",
          "label": "Right gate image"
        },
        {
          "type": "image_picker",
          "id": "simple_gate_image",
          "label": "Simple gate image"
        },
        {
          "type": "range",

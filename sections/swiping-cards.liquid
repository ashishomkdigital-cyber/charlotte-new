{% comment %}
  Tinder-Style Floating Swipe Cards Section
{% endcomment %}

{% liquid
  if template.name == 'product' and product.collections.first
    assign products_list = product.collections.first.products
  elsif template.name == 'collection'
    assign products_list = collection.products
  else
    assign products_list = collections.all.products
  endif
%}

<!-- Floating Trigger Button (Bottom Right) -->
<button type="button" id="OpenSwipeDeckBtn" class="swipe-fab-btn" aria-label="Open Swipe Deck">
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
    <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
    <line x1="12" y1="22.08" x2="12" y2="12"></line>
  </svg>
  <span>Discover</span>
</button>

<!-- Swipe Overlay Modal -->
<div id="SwipeModal" class="swipe-modal" aria-hidden="true">
  <div class="swipe-modal-backdrop" id="SwipeModalBackdrop"></div>

  <div class="swipe-container-wrapper">
    <!-- Close Button -->
    <button type="button" id="CloseSwipeDeckBtn" class="swipe-close-btn" aria-label="Close">
      &times;
    </button>

    <div class="swipe-cards-deck" id="SwipeCardsDeck">
      {% for prod in products_list limit: 20 %}
        {% assign variant = prod.first_available_variant %}
        {% if variant %}
          <div class="swipe-card" 
               data-variant-id="{{ variant.id }}" 
               style="z-index: {{ forloop.rindex }};">
            <div class="card-frame">
              <img src="{{ prod.featured_image | image_url: width: 800 }}" alt="{{ prod.title }}" loading="lazy">
              <div class="card-overlay">
                <span class="card-title">{{ prod.title }}</span>
                <span class="card-divider">|</span>
                <span class="card-price">{{ prod.price | money }}</span>
              </div>
              <div class="swipe-badge swipe-badge-like">ADDED</div>
              <div class="swipe-badge swipe-badge-pass">PASS</div>
            </div>
          </div>
        {% endif %}
      {% else %}
        <div class="no-products-msg">No products left to swipe!</div>
      {% endfor %}
    </div>

    <div class="swipe-instruction-btn">Swipe Right to Add • Left to Pass</div>
  </div>
</div>

<style>
/* Floating Bottom-Right Action Button */
.swipe-fab-btn {
  position: fixed;
  bottom: 24px;
  right: 24px;
  z-index: 9998;
  display: flex;
  align-items: center;
  gap: 8px;
  background: #2b170c;
  color: #e0b07a;
  border: 1px solid #CBA158;
  padding: 12px 20px;
  border-radius: 50px;
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.swipe-fab-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.4);
}

/* Modal Overlay */
.swipe-modal {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.swipe-modal.is-active {
  opacity: 1;
  pointer-events: auto;
}

.swipe-modal-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.75);
  backdrop-filter: blur(5px);
}

/* Modal Content Container */
.swipe-container-wrapper {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 90%;
  max-width: 420px;
  user-select: none;
  -webkit-user-select: none;
}

/* Close Button */
.swipe-close-btn {
  position: absolute;
  top: -45px;
  right: 0;
  background: transparent;
  border: none;
  color: #fff;
  font-size: 2rem;
  line-height: 1;
  cursor: pointer;
  opacity: 0.8;
  transition: opacity 0.2s;
}

.swipe-close-btn:hover {
  opacity: 1;
}

.swipe-cards-deck {
  position: relative;
  width: 100%;
  height: 500px;
}

.swipe-card {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 12px;
  cursor: grab;
  touch-action: none;
  transition: transform 0.2s ease-out;
  will-change: transform;
}

.swipe-card:active {
  cursor: grabbing;
}

.card-frame {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 8px;
  border: 8px solid #CBA158;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  overflow: hidden;
  background: #000;
}

.card-frame img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  pointer-events: none;
}

.card-overlay {
  position: absolute;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(6px);
  padding: 8px 18px;
  border-radius: 20px;
  color: #fff;
  display: flex;
  align-items: center;
  gap: 8px;
  white-space: nowrap;
}

.card-title { font-size: 1rem; font-weight: 500; }
.card-price { font-size: 1rem; opacity: 0.9; }

.swipe-badge {
  position: absolute;
  top: 25px;
  padding: 6px 14px;
  border-radius: 8px;
  font-weight: bold;
  font-size: 1.3rem;
  opacity: 0;
  transition: opacity 0.1s ease;
}

.swipe-badge-like {
  left: 25px;
  border: 3px solid #2ecc71;
  color: #2ecc71;
  transform: rotate(-15deg);
}

.swipe-badge-pass {
  right: 25px;
  border: 3px solid #e74c3c;
  color: #e74c3c;
  transform: rotate(15deg);
}

.swipe-instruction-btn {
  margin-top: 20px;
  width: 100%;
  background: #2b170c;
  color: #e0b07a;
  border: 1px solid #CBA158;
  text-align: center;
  padding: 14px;
  border-radius: 12px;
  font-size: 0.95rem;
  font-weight: 500;
}

.no-products-msg {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: #fff;
  font-size: 1.2rem;
  text-align: center;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const modal = document.getElementById('SwipeModal');
  const openBtn = document.getElementById('OpenSwipeDeckBtn');
  const closeBtn = document.getElementById('CloseSwipeDeckBtn');
  const backdrop = document.getElementById('SwipeModalBackdrop');
  const deck = document.getElementById('SwipeCardsDeck');
  const cards = deck.querySelectorAll('.swipe-card');

  // Toggle Modal Logic
  const openModal = () => {
    modal.classList.add('is-active');
    modal.setAttribute('aria-hidden', 'false');
  };

  const closeModal = () => {
    modal.classList.remove('is-active');
    modal.setAttribute('aria-hidden', 'true');
  };

  openBtn.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);

  // Swipe Engine
  cards.forEach(card => initSwipe(card));

  function initSwipe(card) {
    let startX = 0;
    let startY = 0;
    let currentX = 0;
    let currentY = 0;
    let isDragging = false;

    const likeBadge = card.querySelector('.swipe-badge-like');
    const passBadge = card.querySelector('.swipe-badge-pass');

    const onStart = (e) => {
      isDragging = true;
      startX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
      startY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY;
      card.style.transition = 'none';
    };

    const onMove = (e) => {
      if (!isDragging) return;

      const clientX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
      const clientY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY;

      currentX = clientX - startX;
      currentY = clientY - startY;

      const rotate = currentX * 0.08;
      card.style.transform = `translate3d(${currentX}px, ${currentY}px, 0) rotate(${rotate}deg)`;

      if (currentX > 40) {
        likeBadge.style.opacity = Math.min(currentX / 100, 1);
        passBadge.style.opacity = 0;
      } else if (currentX < -40) {
        passBadge.style.opacity = Math.min(Math.abs(currentX) / 100, 1);
        likeBadge.style.opacity = 0;
      } else {
        likeBadge.style.opacity = 0;
        passBadge.style.opacity = 0;
      }
    };

    const onEnd = () => {
      if (!isDragging) return;
      isDragging = false;
      card.style.transition = 'transform 0.4s ease, opacity 0.4s ease';

      const threshold = 100;

      if (currentX > threshold) {
        card.style.transform = `translate3d(${window.innerWidth}px, ${currentY}px, 0) rotate(45deg)`;
        card.style.opacity = '0';
        addToCart(card.dataset.variantId);
        setTimeout(() => card.remove(), 400);
      } else if (currentX < -threshold) {
        card.style.transform = `translate3d(-${window.innerWidth}px, ${currentY}px, 0) rotate(-45deg)`;
        card.style.opacity = '0';
        setTimeout(() => card.remove(), 400);
      } else {
        card.style.transform = 'translate3d(0, 0, 0) rotate(0deg)';
        likeBadge.style.opacity = 0;
        passBadge.style.opacity = 0;
      }
    };

    card.addEventListener('touchstart', onStart, { passive: true });
    card.addEventListener('touchmove', onMove, { passive: true });
    card.addEventListener('touchend', onEnd);

    card.addEventListener('mousedown', onStart);
    window.addEventListener('mousemove', onMove);
    window.addEventListener('mouseup', onEnd);
  }

  // Ajax Add to Cart
  function addToCart(variantId) {
    const formData = {
      items: [{
        id: parseInt(variantId, 10),
        quantity: 1
      }]
    };

    fetch(window.Shopify.routes.root + 'cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(formData)
    })
    .then(response => response.json())
    .then(() => {
      document.dispatchEvent(new CustomEvent('cart:refresh'));
      document.dispatchEvent(new CustomEvent('cart:updated'));
    })
    .catch((error) => console.error('Error adding to cart:', error));
  }
});
</script>

{% schema %}
{
  "name": "Swipe Cards Modal",
  "settings": [],
  "presets": [
    {
      "name": "Swipe Cards Modal"
    }
  ]
}
{% endschema %}